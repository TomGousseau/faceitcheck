# Public API Key (for basic data access)
FACEIT_PUBLIC_KEY=your_public_key_here

# Private/Server API Key (for enhanced data access)
FACEIT_PRIVATE_KEY=your_private_key_here
# Demo Analysis Settings
# Set to "yes" to enable demo parsing (CPU intensive)
# Set to "no" to disable demo parsing
ENABLE_DEMO_ANALYSIS=no

# Number of demos to analyze per player (default: 3)
# More demos = more accurate data but slower
DEMO_ANALYSIS_COUNT=3

# Demo cache directory (demos are downloaded here)
DEMO_CACHE_DIR=./demo_cache

# Max concurrent demo downloads
MAX_CONCURRENT_DOWNLOADS=2
